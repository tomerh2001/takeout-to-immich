# Published image and container behavior
DOCKER_IMAGE=ghcr.io/tomerh2001/takeout-to-immich:latest
DOCKER_PULL_POLICY=always
DOCKER_NETWORK=bridge
TAKEOUT_UID=1000
TAKEOUT_GID=1000

# Source and staging
SOURCE_REMOTE=google-drive:Takeout
STAGE_DIR=/absolute/path/to/google-photos-staging
BATCH_NAME=
MODE=all

# Local rclone auth
RCLONE_CONFIG_PATH=/absolute/path/to/rclone.conf

# Native immich-go config
IMMICH_GO_CONFIG_HOST_PATH=/absolute/path/to/immich-go.yaml

# Performance and workflow
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=8
UPLOAD_PASSES=2
CLEANUP_AFTER_SUCCESS=false
DRY_RUN=false
