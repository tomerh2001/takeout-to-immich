# Published image and container behavior
DOCKER_IMAGE=ghcr.io/tomerh2001/takeout-to-immich:latest
PULL_IMAGE=true
ALLOW_LOCAL_BUILD=true
DOCKER_NETWORK=
DOCKER_BUILD_NETWORK=
IMMICH_GO_VERSION=v0.31.0

# Source and staging
SOURCE_REMOTE=google-drive:Takeout
STAGE_DIR=/absolute/path/to/google-photos-staging
BATCH_NAME=
MODE=all

# Local rclone auth
RCLONE_CONFIG_PATH=/absolute/path/to/rclone.conf

# Immich
IMMICH_SERVER=https://immich.example.com
IMMICH_API_KEY=replace-with-your-api-key

# Performance and safety
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=8
IMMICH_CONCURRENT_TASKS=4
IMMICH_CLIENT_TIMEOUT=60m
PAUSE_IMMICH_JOBS=true
INCLUDE_UNMATCHED=false
UPLOAD_PASSES=2
CLEANUP_AFTER_SUCCESS=false
DRY_RUN=false

